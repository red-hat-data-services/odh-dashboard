{
  "name": "@odh-dashboard/internal",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test-unit": "jest --silent",
    "test-unit-coverage": "jest --silent --coverage"
  },
  "imports": {
    "#~/*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "exports": {
    "./extensions": "./plugins/extensions/index.ts",
    "./app/AppContext": "./app/AppContext.ts",
    "./app/AppLauncher": "./app/AppLauncher.tsx",
    "./app/ThemeContext": "./app/ThemeContext.tsx",
    "./app/*": null,
    "./plugin/*": null,
    "./third_party/*": null,
    "./*": [
      "./*",
      "./*.ts",
      "./*.d.ts",
      "./*.tsx",
      "./*/index.ts",
      "./*/index.tsx"
    ]
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@module-federation/enhanced": "^0.24.1",
    "@odh-dashboard/app-config": "*",
    "@odh-dashboard/plugin-core": "*",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@swc/core": "^1.15.33",
    "core-js": "^3.49.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "protobufjs": "^7.6.0",
    "react-refresh": "^0.18.0",
    "regenerator-runtime": "^0.14.1",
    "sass": "^1.99.0",
    "slnodejs": "^6.2.12",
    "speed-measure-webpack-plugin": "^1.6.0",
    "swc-loader": "^0.2.7",
    "terser-webpack-plugin": "^5.6.0",
    "webpack-dev-server": "^5.2.4",
    "yaml-eslint-parser": "^1.3.2"
  },
  "devDependencies": {
    "@odh-dashboard/eslint-config": "*"
  }
}
