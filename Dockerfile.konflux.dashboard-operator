FROM registry.access.redhat.com/ubi9/go-toolset:1.26@sha256:981cd8d53cc230b928db75a697586f915da5d3ed6731eddb246ce8865e0b1400 AS builder

USER root

ARG TARGETOS
ARG TARGETARCH
ARG OPERATOR_VERSION=unknown

WORKDIR /usr/src/app

COPY dashboard-operator/go.mod dashboard-operator/go.sum ./
RUN go mod download

COPY dashboard-operator/cmd/ cmd/
COPY dashboard-operator/api/ api/
COPY dashboard-operator/internal/ internal/

RUN CGO_ENABLED=1 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64} go build -a \
    -ldflags="-s -w -X 'github.com/opendatahub-io/odh-dashboard/dashboard-operator/internal/controller.Version=${OPERATOR_VERSION}'" \
    -tags strictfipsruntime -o /tmp/manager ./cmd/manager

FROM registry.access.redhat.com/ubi9/ubi-minimal@sha256:2e8edce823a48e51858f1fad3ff4cbf6875ce8a3f86b9eecf298bc2050c8652a

WORKDIR /

COPY --from=builder /tmp/manager .
COPY manifests/ /opt/manifests/dashboard/

USER 65532:65532

ENTRYPOINT ["/manager"]

LABEL com.redhat.component="odh-dashboard-operator-container" \
      name="managed-open-data-hub/odh-dashboard-operator-rhel9" \
      description="odh-dashboard-operator" \
      summary="odh-dashboard-operator" \
      maintainer="['managed-open-data-hub@redhat.com']" \
      io.openshift.expose-services="" \
      io.k8s.display-name="odh-dashboard-operator" \
      io.k8s.description="odh-dashboard-operator" \
      com.redhat.license_terms="https://www.redhat.com/licenses/Red_Hat_Standard_EULA_20191108.pdf"
